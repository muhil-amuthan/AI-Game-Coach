# AI Game Coach – environment variables
# Copy this file to `.env` and fill in real values for production.
# If a variable is missing, the backend falls back to a built-in default
# (suitable only for local development).

# Flask session signing key
SECRET_KEY=change-me-in-production

# JWT signing key
JWT_SECRET_KEY=change-me-jwt-secret

# Google Gemini API key (optional). When unset, the backend uses a
# lightweight in-process fallback so the app still runs end-to-end.
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
